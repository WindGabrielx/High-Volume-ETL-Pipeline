import pandas as pd
import psycopg2
from psycopg2.extras import execute_values


@data_exporter
def export_data(file_paths, *args, **kwargs):
    conn = psycopg2.connect(
        host="postgres",
        port=5432,
        dbname="pipeline_db",
        user="admin",
        password="admin5555"
    )
    cur = conn.cursor()
    total = 0

    for i, fp in enumerate(file_paths):
        df = pd.read_parquet(fp)
        data = df[['department_name', 'sensor_serial',
                    'product_name', 'product_expire',
                    'create_at']].values.tolist()
        execute_values(cur,
            "INSERT INTO fact_readings (department_name, sensor_serial, product_name, product_expire, create_at) VALUES %s",
            data, page_size=5000
        )
        conn.commit()
        total += len(df)
        del df

        if (i + 1) % 1000 == 0:
            print(f"[{i+1}/{len(file_paths)}] {total:,} rows inserted")

    cur.close()
    conn.close()
    print(f"Finished: {total:,} rows loaded")